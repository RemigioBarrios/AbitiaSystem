{
  "name": "abitia",
  "version": "0.1.0",
  "private": true,
  "description": "Abitia — Sistema de Gestión Integral Multi-Condominio (Fase Magra)",
  "workspaces": [
    "packages/core",
    "packages/data",
    "packages/services",
    "packages/api",
    "packages/web"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:api": "npm run dev -w packages/api",
    "dev:web": "npm run dev -w packages/web",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "typecheck": "tsc -b",
    "test": "npm run test --workspaces"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
